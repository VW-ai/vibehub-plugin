{
  "name": "@vibehub/workbench-app",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && vite build --ssr src/bridge-dogfood.ts --outDir dist-bridge",
    "build:test-harness": "vite build --mode test-harness",
    "test:boundary": "node scripts/verify-production-boundary.mjs",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:production": "playwright test --config playwright.production.config.ts"
  },
  "dependencies": {
    "@vibehub/core": "workspace:*",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vitest": "^2.1.8"
  }
}
