{
  "name": "@vibehub/core",
  "version": "0.0.1",
  "description": "Vibehub workbench core — library-first, zero-LLM (decision-project-013/025). All real logic lives here; cli/mcp are thin adapters.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "better-sqlite3": "^11.8.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
